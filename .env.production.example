# ══════════════════════════════════════════════════════════════════════════════
# PRODUCTION ENVIRONMENT — Headless WordPress Setup
# Server pe ye variables manually set karo (ya Vercel/EC2 environment mein)
# Is file mein real values mat daalo — sirf reference ke liye hai
# ══════════════════════════════════════════════════════════════════════════════

NODE_ENV="production"

# ── Headless WordPress (Hostinger) ────────────────────────────────────────────
WP_GRAPHQL_URL="https://design2wp.in/vitaminc/graphql"
WP_URL="https://design2wp.in/vitaminc"

# ── Next.js Public ────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# ── Migration Script (only needed when running migrate-to-wp.ts) ──────────────
# WP Admin → Users → Profile → Application Passwords
WP_MIGRATE_USER="your-wp-username"
WP_MIGRATE_PASS="xxxx xxxx xxxx xxxx xxxx xxxx"
