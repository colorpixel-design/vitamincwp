# ──────────────────────────────────────────────────────────────────────
# PRODUCTION ENVIRONMENT — bestcserum.com
# These values live in AWS SSM Parameter Store on the server.
# This file is a REFERENCE ONLY. Never put real values here.
# ──────────────────────────────────────────────────────────────────────

NODE_ENV="production"

# Database — AWS RDS PostgreSQL (private subnet, Mumbai ap-south-1)
DATABASE_URL="postgresql://vitaminc:STRONG_PASSWORD@YOUR_RDS_ENDPOINT.ap-south-1.rds.amazonaws.com:5432/vitaminc_db"

# Auth — generate with: openssl rand -hex 32
JWT_SECRET="REPLACE_WITH_32_CHAR_RANDOM_STRING"

# AWS S3 — EC2 uses IAM Role (no access keys needed on the server!)
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="bestcserum-assets"

# CloudFront CDN URL (fill after CloudFront setup)
NEXT_PUBLIC_CDN_URL="https://assets.bestcserum.com"
